# Build artifacts — generated by `npm run build`, never commit.
# bridge/ holds two hand-authored source assets (gyoshu_bridge.py,
# run-mcp-server.sh) alongside generated .cjs/.js bundles, so ignore only
# the generated outputs — not the whole directory.
dist/
bridge/*.cjs
bridge/*.js

__pycache__/
*.py[cod]
